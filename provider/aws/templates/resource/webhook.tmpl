{{ define "resource" }}
{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Parameters": {
    "NotificationTopic": {
      "Type": "String"
    },
    "Url": {
      "Type": "String",
      "Description": "Webhook URL"
    }
  },
  "Resources": {
    "Forwarder": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "ZipFile": { "Fn::Join": [ "\n", [
            "const https = require(\"https\");",
            "const url = require(\"url\");",
            "exports.handler = async (event) => {",
            "  return new Promise((resolve, reject) => {",
            "    const req = https.request(",
            "      Object.assign(url.parse(process.env.WEBHOOK_URL), { method: \"POST\" }),",
            "      (res) => {",
            "        let data = '';",
            "        res.on('data', (chunk) => {",
            "          data += chunk;",
            "        });",
            "        res.on('end', () => {",
            "          resolve(200);",
            "        });",
            "      }",
            "    );",
            "    req.on('error', (e) => {",
            "      reject(e);",
            "    });",
            "    req.write(event.Records[0].Sns.Message);",
            "    req.end();",
            "  });",
            "};"
          ] ] }
        },
        "Environment": { "Variables": { "WEBHOOK_URL": { "Ref": "Url" } } },
        "Handler": "index.handler",
        "Role": { "Fn::GetAtt": [ "ForwarderRole", "Arn" ] },
        "Runtime": "nodejs22.x",
        "Timeout": "10"
      }
    },
    "ForwarderPermission": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": { "Fn::GetAtt": [ "Forwarder", "Arn" ] },
        "Principal": "sns.amazonaws.com",
        "SourceArn": { "Ref": "NotificationTopic" }
      }
    },
    "ForwarderRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [ { "Effect": "Allow", "Principal": { "Service": [ "lambda.amazonaws.com" ] }, "Action": "sts:AssumeRole" } ]
        },
        "ManagedPolicyArns": [ { "Fn::Sub": "arn:${AWS::Partition}:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole" } ],
        "Path": "/convox/"
      }
    },
    "Subscription": {
      "Type": "AWS::SNS::Subscription",
      "Properties": {
        "Endpoint": { "Fn::GetAtt": [ "Forwarder", "Arn" ] },
        "Protocol": "lambda",
        "TopicArn": { "Ref": "NotificationTopic" }
      }
    }
  }
}
{{ end }}
